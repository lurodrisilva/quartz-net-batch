{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Quartz": "Debug",
        "System": "Information"
      }
    }
  },

  "ConnectionStrings": {
    "QuartzDatabase": "Server=localhost,1433;Database=QuartzDB;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true;Encrypt=false"
  },

  "Quartz": {
    "Clustered": false,
    "ThreadPoolSize": 5,
    "PerformSchemaValidation": true
  },

  "JobSchedules": {
    "RecurringJob": {
      "CronExpression": "0/30 * * * * ?",
      "BatchSize": 10
    },
    "OneTimeJob": {
      "DelaySeconds": 10
    }
  }
}
