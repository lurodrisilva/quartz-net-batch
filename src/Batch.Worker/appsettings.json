{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Quartz": "Information",
        "System": "Warning"
      }
    }
  },

  "ConnectionStrings": {
    "QuartzDatabase": ""
  },

  "Quartz": {
    "SchedulerName": "BatchScheduler",
    "InstanceId": "AUTO",
    "ThreadPoolSize": 10,
    "MaxBatchSize": 5,
    "Clustered": true,
    "ClusterCheckinIntervalMs": 15000,
    "MisfireThresholdMs": 60000,
    "TablePrefix": "QRTZ_",
    "PerformSchemaValidation": true
  },

  "JobSchedules": {
    "RecurringJob": {
      "Enabled": true,
      "CronExpression": "0 0/5 * * * ?",
      "BatchSize": 100,
      "MaxRetries": 3
    },
    "OneTimeJob": {
      "Enabled": true,
      "DelaySeconds": 30
    }
  },

  "Dynatrace": {
    "Enabled": true
  }
}
